{
  "name": "multi-tenant-feature-flags",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-tenant feature flag management assignment",
  "main": "backend/server.js",
  "scripts": {
    "build": "vite build --config frontend/vite.config.js",
    "start": "npm run build && node backend/server.js",
    "dev": "concurrently -n API,WEB -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "node --watch backend/server.js",
    "dev:web": "vite --config frontend/vite.config.js",
    "test": "node --test"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "morgan": "^1.10.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "vite": "^6.3.5"
  }
}
